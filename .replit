modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[userenv]

[userenv.shared]
DRY_RUN = "false"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Agent Wealth Builder"

[[workflows.workflow]]
name = "AI Agent Wealth Builder"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "gce"
run = ["python", "main.py"]
ignorePorts = true
