# ============================================================================
# AI Agent Wealth Builder - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it contains secrets!)
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Examples:
#   Local:     postgresql://trading_user:password@localhost:5432/wealth_builder
#   Docker:    postgresql://trading_user:password@postgres:5432/wealth_builder
#   Remote:    postgresql://user:pass@db.example.com:5432/wealth_builder
DATABASE_URL=postgresql://trading_user:trading_secure_pass@localhost:5432/wealth_builder

# Database credentials (used by docker-compose)
DB_USER=trading_user
DB_PASSWORD=trading_secure_pass
DB_NAME=wealth_builder

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================

# Your OpenAI API Key
# Get from: https://platform.openai.com/account/api-keys
# Format: sk-...
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use (change for different models, e.g., gpt-4)
OPENAI_MODEL=gpt-4

# ============================================================================
# WEB3 / POLYGON CONFIGURATION
# ============================================================================

# Your Polygon private key (starts with 0x)
# NEVER share this! Keep it secret.
# For testing: use test wallet
# For production: use secure key management (e.g., AWS Secrets Manager)
POLYGON_PRIVATE_KEY=0xyour_polygon_private_key_here_64_hex_chars

# Polygon RPC URL
# Public endpoints:
#   https://polygon-rpc.com
#   https://polygonapi.terminet.io/rpc
#   https://rpc-mainnet.inging.io
# Or use Alchemy/Infura endpoint for better reliability
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygon wallet address (derived from private key)
# Leave empty to auto-derive from POLYGON_PRIVATE_KEY
POLYGON_ADDRESS=0xyour_wallet_address_here

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================

# DRY_RUN: true = simulated trades (no real money), false = live trading
# DEFAULT: true (for safety)
# CRITICAL: Always test with DRY_RUN=true first!
DRY_RUN=true

# How often to run trading cycle (minutes)
# Default: 10 (run every 10 minutes)
# Range: 5-60 recommended
CYCLE_INTERVAL_MINUTES=10

# How often to update/display dashboard (minutes)
# Default: 30
DASHBOARD_INTERVAL_MINUTES=30

# Maximum allowed drawdown before pausing trading (%)
# Default: 10 (pause if you lose 10% of capital)
# Range: 5-20 recommended
# Set higher for aggressive, lower for conservative
MAX_DRAWDOWN_PCT=10

# Kelly Criterion fraction (position sizing)
# Default: 0.25 (use 25% of Kelly for safety)
# Full Kelly: 1.0 (prone to ruin)
# Conservative: 0.1 (very safe)
# Aggressive: 0.5 (high risk/reward)
# Range: 0.1-1.0
KELLY_FRACTION=0.25

# Minimum confidence threshold for trading (0-1)
# Default: 0.60 (only trade if 60%+ confident)
# Higher = fewer but more confident trades
# Lower = more trades but less reliable
MIN_CONFIDENCE_THRESHOLD=0.60

# ============================================================================
# API / MONITORING CONFIGURATION
# ============================================================================

# API Port for monitoring dashboard/endpoints
API_PORT=8000

# API Host binding
API_HOST=0.0.0.0

# Enable REST API endpoint (true/false)
ENABLE_API=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEFAULT: INFO (balanced)
# Use DEBUG for development/troubleshooting
# Use INFO for production
LOG_LEVEL=INFO

# Audit log file path
AUDIT_LOG_FILE=logs/audit.log

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# ML Model retraining
# Retrain model every 24 hours if enough data exists (50+ resolved trades)
ML_RETRAIN_ENABLED=true
ML_MIN_SAMPLES_RETRAIN=50

# Rate limiting
# Maximum API calls per minute
RATE_LIMIT_PER_MINUTE=60

# Request timeout (seconds)
REQUEST_TIMEOUT_SECONDS=30

# Retry policy
# How many times to retry failed API calls
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5

# ============================================================================
# POLYMARKET CONFIGURATION
# ============================================================================

# Polymarket API endpoint
POLYMARKET_API_URL=https://api.polymarket.com

# Market filters (optional)
# Only trade markets matching these criteria
MARKET_MIN_LIQUIDITY_USD=1000
MARKET_MAX_SPREAD_PERCENT=10

# ============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ============================================================================

# Development
# UNCOMMENT these for development/testing
# DRY_RUN=true
# CYCLE_INTERVAL_MINUTES=5
# LOG_LEVEL=DEBUG
# KELLY_FRACTION=0.1

# Staging
# UNCOMMENT for staging/pre-production testing
# DRY_RUN=false
# CYCLE_INTERVAL_MINUTES=30
# MAX_DRAWDOWN_PCT=5
# KELLY_FRACTION=0.1
# LOG_LEVEL=INFO

# Production
# UNCOMMENT for production (live trading)
# DRY_RUN=false
# CYCLE_INTERVAL_MINUTES=10
# MAX_DRAWDOWN_PCT=10
# KELLY_FRACTION=0.25
# LOG_LEVEL=INFO

# ============================================================================
# SECURITY NOTES
# ============================================================================

# 1. NEVER commit .env to git
#    Add .env to .gitignore (already done in this repo)

# 2. Store secrets securely:
#    - Local: Use .env with restricted file permissions (chmod 600)
#    - Docker: Use docker secrets or environment variables
#    - Vercel: Use dashboard Environment Variables
#    - AWS: Use AWS Secrets Manager
#    - GCP: Use Cloud Secret Manager

# 3. Rotate keys regularly:
#    - Change OPENAI_API_KEY quarterly
#    - Change POLYGON_PRIVATE_KEY if compromised
#    - Use different keys for dev/staging/prod

# 4. Minimal permissions:
#    - Polygon wallet: Only holds trading capital
#    - OpenAI API key: Only use on trusted infrastructure
#    - Database password: Strong, unique, rotated regularly

# ============================================================================
